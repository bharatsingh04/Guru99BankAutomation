pipeline {
    agent any

    tools {
        jdk 'JDK'
        maven 'Maven3'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                url: 'https://github.com/Yash28102/Caps_Project.git'
            }
        }

        stage('Verify Workspace') {
            steps {
                bat 'dir'
                bat 'dir /s'
            }
        }
	stage('Compile') {
            steps {
				dir('Guru99BankFramework'){
                bat 'mvn compile'
            }
        }
        }
        stage('Build and Test') {
            steps {
                dir('Guru99BankFramework') {
                    bat 'mvn clean'
                }
            }
        }
 
        stage('Test') {
            steps {
				dir('Guru99BankFramework'){
                bat 'mvn test'
            }
        }
        }
 
        

        stage('Package') {
            steps {
                dir('Guru99BankFramework') {
                    bat 'mvn package -DskipTests'
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('Guru99BankFramework') {
                    bat 'docker build -t testng-framework .'
                }
            }
        }
stage('Docker Run') {
            steps {
                dir('Guru99BankFramework') {
                    bat 'docker run testng-framework'
                }
            }
        }
    }

    post {
        always {
            junit '**/target/surefire-reports/*.xml'
            archiveArtifacts '**/target/*.jar'
        }
    }
}
